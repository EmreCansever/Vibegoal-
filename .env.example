# ── API-Sports (https://www.api-football.com/) ──
FOOTBALL_API_KEY=your_api_sports_key_here
# VITE_FOOTBALL_API_KEY=your_api_sports_key_here

# ── Firebase Admin (sync script) ──
FIREBASE_PROJECT_ID=your_firebase_project_id
# VITE_FIREBASE_PROJECT_ID=your_firebase_project_id

# Service account JSON dosya yolu (Firebase Console → Project Settings → Service accounts)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# Alternatif: JSON içeriğini tek satır olarak (CI için)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
